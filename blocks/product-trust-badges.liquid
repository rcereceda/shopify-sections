{% stylesheet %}
  .product-trust-badges {
    margin-top: var(--margin-top);
  }

  .product-trust-badges-list {
    display: flex;
    flex-direction: column;
    gap: var(--badge-gap);
  }

  .product-trust-badge-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .product-trust-badge-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: var(--badge-icon-color);
  }

  .product-trust-badge-icon svg {
    width: 100%;
    height: 100%;
  }

  .product-trust-badge-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    color: var(--badge-text-color);
  }

  .product-trust-badge-text strong {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
  }

  .product-trust-badge-text span {
    font-size: 13px;
    line-height: 1.4;
    opacity: 0.8;
  }
{% endstylesheet %}

{% schema %}
